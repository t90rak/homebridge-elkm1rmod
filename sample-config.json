// Elk M1 plugin configuration for Homebridge
{
  "platform": "ElkM1",
  "elkAddress": "192.168.1.100",        // IP of your Elk M1 panel
  "elkPort": 2101,                      // Default port for M1XEP
  "keypadCode": "1234",                 // Your Elk user code
  "area": 1,                            // Area number to control

  "zoneTypes": [
    { "zoneNumber": 1, "zoneType": "contact" },
    { "zoneNumber": 2, "zoneType": "motion" },
    { "zoneNumber": 3, "zoneType": "smoke" }
  ],

  "garageDoors": [
    {
      "stateZone": "4",
      "openOutput": "1",
      "closeOutput": "2",
      "name": "Garage Door"
    }
  ],

  "includedTasks": [1, 2],
  "includedOutputs": [3, 4],
  "logElkData": false
}
